# Default local development configuration
# Use mock mode unless you want to validate a real LLM provider.
LLM_PROVIDER=mock

# Set only when using the matching real provider.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional local paths
LOG_PATH=mock_db/log.json

# VSH Extension Settings
VSH_API_URL=http://localhost:3000
VITE_VSH_API_URL=http://localhost:3000
VSH_WATCH_ON_SAVE=false
# CHROMA_DB_DIR=.chroma_db
# CHROMA_CACHE_DIR=.cache/chroma

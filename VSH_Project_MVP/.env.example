# =========================
# VSH runtime defaults
# =========================
# mock | gemini | openai
LLM_PROVIDER=mock

# Gemini uses GOOGLE_API_KEY by default.
# GEMINI_API_KEY is kept for backward compatibility.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# OpenAI (used only when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4.1-mini

# Optional local paths
LOG_PATH=mock_db/log.json

# Desktop / Extension API URL
VSH_API_URL=http://127.0.0.1:3000
VITE_VSH_API_URL=http://127.0.0.1:3000
VSH_WATCH_ON_SAVE=false

# Set to false to disable API auto-start in Electron
VSH_AUTO_START_API=true

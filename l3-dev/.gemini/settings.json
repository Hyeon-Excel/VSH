{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "rules-check",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/rules_check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}